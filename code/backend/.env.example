PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sb-stocks?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=
JWT_EXPIRE=30d
FINNHUB_API_KEY=
NODE_ENV=development

# Netlify frontend origin, for CORS lock-down in production (falls back to * if unset)
CLIENT_URL=

# Shared secret Vercel Cron Jobs send as `Authorization: Bearer $CRON_SECRET`.
# Set the same value here and as a Vercel project env var.
CRON_SECRET=
